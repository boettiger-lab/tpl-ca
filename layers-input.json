{
    "catalog": "https://s3-west.nrp-nautilus.io/public-data/stac/catalog.json",
    "titiler_url": "https://titiler.nrp-nautilus.io",
    "mcp_url": "https://duckdb-mcp.nrp-nautilus.io/mcp",
    "view": {
        "center": [-119.5, 37.5],
        "zoom": 6
    },
    "welcome": {
        "message": "Hi! I can help you explore California protected lands and conservation data. Try asking:",
        "examples": [
            "Tell me about the datasets you have access to.",
            "What are the top 10 counties by total CPAD-protected acreage?",
            "Show only open-access protected lands.",
            "Color the protected lands by managing agency type.",
            "Which congressional districts have the most irrecoverable carbon?"
        ]
    },
    "collections": [
        {
            "collection_id": "wetlands-global-unified",
            "collection_url": "https://s3-west.nrp-nautilus.io/public-wetlands/stac-collection.json",
            "assets": [
                {
                    "id": "glwd-main-class-cog",
                    "display_name": "Wetland Type (GLWD)",
                    "group": "Wetlands",
                    "visible": false,
                    "legend_type": "categorical"
                }
            ]
        },
        {
            "collection_id": "irrecoverable-carbon",
            "collection_url": "https://s3-west.nrp-nautilus.io/public-carbon/stac-collection.json",
            "assets": [
                {
                    "id": "v2-irrecoverable-2024-cog",
                    "display_name": "Irrecoverable Carbon (2024)",
                    "group": "Carbon",
                    "visible": false,
                    "colormap": "reds",
                    "rescale": "0,150"
                }
            ]
        },
        {
            "collection_id": "svi-2022",
            "collection_url": "https://s3-west.nrp-nautilus.io/public-social-vulnerability/2022/stac-collection.json",
            "assets": [
                {
                    "id": "county-pmtiles",
                    "display_name": "SVI (county)",
                    "group": "Social Vulnerability",
                    "visible": false,
                    "default_style": {
                        "fill-color": ["interpolate", ["linear"], ["get", "RPL_THEMES"],
                            0,   "#1A9641",
                            0.25, "#A6D96A",
                            0.5,  "#FFFFBF",
                            0.75, "#FDAE61",
                            1,   "#D7191C"
                        ],
                        "fill-opacity": 0.7
                    },
                    "outline_style": {
                        "line-color": "#555555",
                        "line-width": 0.5
                    },
                    "default_filter": ["==", ["get", "ST_ABBR"], "CA"],
                    "tooltip_fields": ["COUNTY", "FIPS", "RPL_THEMES", "ST_ABBR"]
                },
                {
                    "id": "tract-pmtiles",
                    "display_name": "SVI (tract)",
                    "group": "Social Vulnerability",
                    "visible": false,
                    "default_style": {
                        "fill-color": ["interpolate", ["linear"], ["get", "RPL_THEMES"],
                            0,   "#1A9641",
                            0.25, "#A6D96A",
                            0.5,  "#FFFFBF",
                            0.75, "#FDAE61",
                            1,   "#D7191C"
                        ],
                        "fill-opacity": 0.7
                    },
                    "outline_style": {
                        "line-color": "#555555",
                        "line-width": 0.5
                    },
                    "default_filter": ["==", ["get", "ST_ABBR"], "CA"],
                    "tooltip_fields": ["COUNTY", "FIPS", "RPL_THEMES", "ST_ABBR"]
                }
            ]
        },
