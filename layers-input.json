{
    "catalog": "https://s3-west.nrp-nautilus.io/public-data/stac/catalog.json",
    "titiler_url": "https://titiler.nrp-nautilus.io",
    "mcp_url": "https://duckdb-mcp.nrp-nautilus.io/mcp",
    "view": {
        "center": [-119.5, 37.5],
        "zoom": 6
    },
    "welcome": {
        "message": "Hi! I can help CA legislators and advocates explore land conservation and public investment data by district. Try asking:",
        "examples": [
            "Which programs and agencies have funded land conservation in Congressional District 16, and how much?",
            "Which congressional districts have raised the most conservation funding through ballot measures since 2010?",
            "Which CA congressional districts have had failed conservation ballot measures, and how much funding was at stake?",
            "Which Assembly districts have the most protected acreage recorded in the Conservation Almanac?",
            "How much has the Land and Water Conservation Fund invested in Senate District 2?",
            "Show me conservation sites that overlap high-pollution communities using CalEnviroScreen."
        ]
    },
    "collections": [
        {
            "collection_id": "calfire-2024-firep",
            "collection_url": "https://s3-west.nrp-nautilus.io/public-fire/calfire-2024/firep/stac-collection.json",
            "assets": [
                {
                    "id": "firep-pmtiles",
                    "display_name": "Wildfire Perimeters",
                    "group": "Fire",
                    "visible": false,
                    "default_filter": [">=", ["get", "YEAR_"], 2000],
                    "default_style": {
                        "fill-color": ["interpolate", ["linear"], ["get", "YEAR_"],
                            2000, "#FFCCBC",
                            2015, "#FF7043",
                            2024, "#B71C1C"
                        ],
                        "fill-opacity": 0.5
                    },
                    "outline_style": {
                        "line-color": "#B71C1C",
                        "line-width": 0.5
                    },
                    "tooltip_fields": ["FIRE_NAME", "YEAR_", "GIS_ACRES", "AGENCY", "CAUSE"]
                }
            ]
        },
        {
            "collection_id": "calfire-2024-rxburn",
